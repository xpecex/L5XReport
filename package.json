{
  "name": "L5XReport",
  "version": "1.0.0",
  "description": "Electron app that scans L5X files (Rockwell/Allen-Bradley Logix controller XML backups) to detect bypass conditions in ladder logic and generates audit reports",
  "license": "GPLv2",
  "author": {
    "name": "Pedro Filipe C Ferreira",
    "email": "xpecex@outlook.com",
    "url": "https://github.com/xpecex/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xpecex/L5XReport.git"
  },
  "bugs": {
    "url": "https://github.com/xpecex/L5XReport/issues"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test:unit": "node __TEST/bypass.unit.test.js",
    "test:e2e": "cmd /c set E2E_TEST=true&&npx playwright test e2e",
    "build:bundler": "rollup -c rollup.config.js",
    "build:package": "npm exec --package=electron-builder -- electron-builder",
    "build:full": "cmd /c npm run build:bundler && npm run build:package"
  },
  "devDependencies": {
    "@playwright/electron": "^0.0.1",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-terser": "^1.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.60.0",
    "rollup": "^4.60.3"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  },
  "build": {
    "appId": "xpecex.L5XReport",
    "productName": "L5XReport",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asar": true,
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "extraMetadata": {
      "version": "1.0.0",
      "description": "Electron app that scans L5X files (Rockwell/Allen-Bradley Logix controller XML backups) to detect bypass conditions in ladder logic and generates audit reports",
      "author": "Pedro Filipe C Ferreira"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "keywords": [
    "l5x",
    "rockwell",
    "logix",
    "bypass"
  ]
}